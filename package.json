{
  "name": "st-anamnesis-engine",
  "version": "0.1.0",
  "description": "Redis-backed knowledge graph builder for git repositories with pluggable grammar extractors",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev:api": "tsx src/index.ts",
    "dev:worker": "tsx src/worker.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bullmq": "^5.40.2",
    "fastify": "^5.2.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-shortest-path": "^2.1.0",
    "ioredis": "^5.5.0",
    "openai": "^6.45.0",
    "simple-git": "^3.27.0",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.25.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
